{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(ls *)",
      "Bash(cd *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run type-check)",
      "Bash(npm run check)",
      "Bash(npm run dev)",
      "Bash(npm run dev:local)",
      "Bash(npm run build:*)",
      "Bash(npm run deploy:dev)",
      "Bash(npx jest*)",
      "Bash(aio app test*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git stash list)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh run:*)"
    ],
    "deny": [
      "Bash(npm run deploy:stage)",
      "Bash(npm run deploy:prod)",
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git merge *)",
      "Bash(* --force)",
      "Bash(sudo *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/cod87753/Code/ai-council/packages/cli/dist/hooks/claude-code-post-tool.cjs\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/cod87753/Code/ai-council/packages/cli/dist/hooks/claude-code-pre-tool.cjs\""
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "pim": {
      "command": "npx",
      "args": [
        "-y",
        "@pim/mcp-server@0.1.0"
      ],
      "env": {
        "PIM_API_URL": "https://d1ygncl0yqo6sv.cloudfront.net"
      }
    }
  }
}
