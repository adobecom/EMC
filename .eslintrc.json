{
    "env": {
        "es6": true,
        "node": true
    },
    "extends": ["eslint:recommended", "plugin:jest/recommended"],
    "parserOptions": {
        "ecmaVersion": "latest"
    },
    "overrides": [
        {
            "files": ["web-src/**/*.js"],
            "env": {
                "browser": true,
                "es6": true
            },
            "parserOptions": {
                "ecmaVersion": "latest",
                "sourceType": "module"
            }
        },
        {
            "files": ["docs/**/*.js"],
            "parserOptions": {
                "ecmaVersion": "latest",
                "sourceType": "module"
            }
        }
    ]
}